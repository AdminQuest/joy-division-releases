{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/adminquest/joy-division-releases/schema/variant.schema.json",
  "title": "Joy Division release variant",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "variant_id",
    "release_type",
    "canonical_title",
    "canonical_artist",
    "documentation_quality",
    "format_details"
  ],
  "properties": {
    "variant_id": {
      "type": "string",
      "pattern": "^(OFF|PIR|BOOT|VID|BOX|BOOK|PARA)-[A-Z0]-[0-9]{4}$"
    },
    "release_type": {
      "type": "string",
      "enum": [
        "officiel",
        "pirate",
        "bootleg",
        "video",
        "coffret",
        "livre",
        "para"
      ]
    },
    "canonical_title": {
      "type": "string",
      "minLength": 1
    },
    "canonical_artist": {
      "type": "string",
      "default": "Joy Division"
    },
    "year": {
      "type": "integer",
      "minimum": 1976,
      "maximum": 2030
    },
    "documentation_quality": {
      "type": "string",
      "enum": ["verified", "needs_review", "stub"]
    },
    "format_details": {
      "type": "object"
    },
    "joydiv_letter": {
      "type": ["string", "null"],
      "pattern": "^[A-Z0]$"
    },
    "joydiv_url": {
      "type": ["string", "null"],
      "format": "uri"
    },
    "discogs_release_id": {
      "type": ["string", "null"]
    },
    "discogs_url": {
      "type": ["string", "null"],
      "format": "uri"
    },
    "other_sources": {
      "type": "array",
      "items": {"type": "string", "format": "uri"},
      "default": []
    },
    "release_date": {
      "type": ["string", "null"],
      "format": "date"
    },
    "country_or_pressing_place": {
      "type": ["string", "null"]
    },
    "edition": {
      "anyOf": [
        {"type": "null"},
        {"$ref": "#/$defs/edition"}
      ]
    },
    "distribution": {
      "anyOf": [
        {"type": "null"},
        {"$ref": "#/$defs/distribution"}
      ]
    },
    "sources": {
      "type": "array",
      "items": {"type": "string"},
      "default": []
    },
    "notes": {
      "type": ["string", "null"]
    },
    "_legacy_code": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "release_type": {"enum": ["officiel", "pirate", "bootleg"]}
        },
        "required": ["release_type"]
      },
      "then": {
        "properties": {
          "format_details": {"$ref": "#/$defs/audio_format"}
        }
      }
    },
    {
      "if": {
        "properties": {"release_type": {"const": "video"}},
        "required": ["release_type"]
      },
      "then": {
        "properties": {
          "format_details": {"$ref": "#/$defs/video_format"}
        }
      }
    },
    {
      "if": {
        "properties": {"release_type": {"const": "coffret"}},
        "required": ["release_type"]
      },
      "then": {
        "properties": {
          "format_details": {"$ref": "#/$defs/box_format"}
        }
      }
    },
    {
      "if": {
        "properties": {"release_type": {"const": "livre"}},
        "required": ["release_type"]
      },
      "then": {
        "properties": {
          "format_details": {"$ref": "#/$defs/book_format"}
        }
      }
    },
    {
      "if": {
        "properties": {"release_type": {"const": "para"}},
        "required": ["release_type"]
      },
      "then": {
        "properties": {
          "format_details": {"$ref": "#/$defs/para_format"}
        }
      }
    }
  ],
  "$defs": {
    "edition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["is_limited", "numbered"],
      "properties": {
        "is_limited": {"type": "boolean"},
        "total_copies": {
          "anyOf": [
            {"type": "null"},
            {"type": "integer", "minimum": 0}
          ]
        },
        "numbered": {"type": "boolean"},
        "notes": {"type": ["string", "null"]}
      }
    },
    "distribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["channel"],
      "properties": {
        "channel": {
          "type": "string",
          "enum": ["commercial", "promo", "press", "private_pressing"]
        },
        "notes": {"type": ["string", "null"]}
      }
    },
    "audio_format": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "supports"],
      "properties": {
        "type": {"const": "audio"},
        "supports": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/audio_support"}
        },
        "label_apparent": {"type": ["string", "null"]},
        "catalog_number": {"type": ["string", "null"]},
        "content": {
          "anyOf": [
            {"type": "null"},
            {"$ref": "#/$defs/audio_content"}
          ]
        }
      }
    },
    "audio_support": {
      "type": "object",
      "additionalProperties": false,
      "required": ["support_type", "count"],
      "properties": {
        "support_type": {
          "type": "string",
          "enum": ["vinyl", "cd", "cassette", "flexi", "reel"]
        },
        "count": {"type": "integer", "minimum": 1},
        "size": {"type": ["string", "null"]},
        "speed": {
          "anyOf": [
            {"type": "null"},
            {"type": "integer", "enum": [33, 45, 78]}
          ]
        },
        "color": {"type": ["string", "null"]},
        "weight_grams": {
          "anyOf": [
            {"type": "null"},
            {"type": "integer", "exclusiveMinimum": 0}
          ]
        },
        "matrices": {
          "type": "array",
          "items": {"type": "string"},
          "default": []
        }
      }
    },
    "audio_content": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tracklist": {
          "anyOf": [
            {"type": "null"},
            {
              "type": "array",
              "items": {"$ref": "#/$defs/audio_tracklist_side"}
            }
          ]
        },
        "global_notes": {"type": ["string", "null"]}
      }
    },
    "audio_tracklist_side": {
      "type": "object",
      "additionalProperties": false,
      "required": ["side", "tracks"],
      "properties": {
        "side": {"type": "string"},
        "tracks": {
          "type": "array",
          "items": {"$ref": "#/$defs/audio_track"}
        }
      }
    },
    "audio_track": {
      "type": "object",
      "additionalProperties": false,
      "required": ["position", "title"],
      "properties": {
        "position": {"type": "integer", "minimum": 1},
        "title": {"type": "string"},
        "duration": {
          "anyOf": [
            {"type": "null"},
            {"type": "string", "pattern": "^[0-9]+:[0-5][0-9]$"}
          ]
        },
        "source_session": {"type": ["string", "null"]}
      }
    },
    "video_format": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "supports"],
      "properties": {
        "type": {"const": "video"},
        "supports": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/video_support"}
        },
        "catalog_number": {"type": ["string", "null"]},
        "content": {
          "anyOf": [
            {"type": "null"},
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "chapters": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["position", "title"],
                    "properties": {
                      "position": {"type": "integer"},
                      "title": {"type": "string"}
                    }
                  }
                },
                "global_notes": {"type": ["string", "null"]}
              }
            }
          ]
        }
      }
    },
    "video_support": {
      "type": "object",
      "additionalProperties": false,
      "required": ["support_type", "count"],
      "properties": {
        "support_type": {
          "type": "string",
          "enum": ["dvd", "vhs", "bluray", "umd"]
        },
        "count": {"type": "integer", "minimum": 1},
        "region": {"type": ["string", "null"]},
        "video_format": {
          "anyOf": [
            {"type": "null"},
            {"type": "string", "enum": ["PAL", "NTSC", "multi"]}
          ]
        },
        "aspect_ratio": {"type": ["string", "null"]},
        "duration_minutes": {
          "anyOf": [
            {"type": "null"},
            {"type": "integer", "exclusiveMinimum": 0}
          ]
        },
        "languages": {
          "type": "array",
          "items": {"type": "string"},
          "default": []
        },
        "subtitles": {
          "type": "array",
          "items": {"type": "string"},
          "default": []
        }
      }
    },
    "box_format": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "components"],
      "properties": {
        "type": {"const": "box"},
        "components": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["variant_id_ref", "role"],
            "properties": {
              "variant_id_ref": {
                "type": "string",
                "pattern": "^(OFF|PIR|BOOT|VID|BOX|BOOK|PARA)-[A-Z0]-[0-9]{4}$"
              },
              "role": {"type": "string"}
            }
          }
        },
        "additional_items": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "description"],
            "properties": {
              "type": {"type": "string"},
              "description": {"type": "string"}
            }
          },
          "default": []
        },
        "box_dimensions_mm": {
          "anyOf": [
            {"type": "null"},
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["width", "height", "depth"],
              "properties": {
                "width": {"type": "integer"},
                "height": {"type": "integer"},
                "depth": {"type": "integer"}
              }
            }
          ]
        },
        "catalog_number": {"type": ["string", "null"]}
      }
    },
    "book_format": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "authors",
        "publisher",
        "publication_year",
        "language",
        "format_physical",
        "illustrations",
        "has_appendices"
      ],
      "properties": {
        "type": {"const": "book"},
        "isbn_13": {
          "anyOf": [
            {"type": "null"},
            {"type": "string", "pattern": "^97[89]-[0-9-]+$"}
          ]
        },
        "isbn_10": {
          "anyOf": [
            {"type": "null"},
            {"type": "string", "pattern": "^[0-9X-]+$"}
          ]
        },
        "authors": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        },
        "publisher": {"type": "string"},
        "publication_year": {
          "type": "integer",
          "minimum": 1900,
          "maximum": 2030
        },
        "page_count": {
          "anyOf": [
            {"type": "null"},
            {"type": "integer", "exclusiveMinimum": 0}
          ]
        },
        "language": {"type": "string", "pattern": "^[a-z]{2}$"},
        "format_physical": {
          "type": "string",
          "enum": ["softcover", "hardcover", "jacketed_hardcover"]
        },
        "dimensions_mm": {
          "anyOf": [
            {"type": "null"},
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["width", "height", "depth"],
              "properties": {
                "width": {"type": "integer"},
                "height": {"type": "integer"},
                "depth": {"type": "integer"}
              }
            }
          ]
        },
        "illustrations": {"type": "boolean"},
        "has_appendices": {"type": "boolean"},
        "catalog_number": {"type": ["string", "null"]},
        "content": {
          "anyOf": [
            {"type": "null"},
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "table_of_contents": {"type": ["string", "null"]}
              }
            }
          ]
        }
      }
    },
    "para_format": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "parent_object", "object_description"],
      "properties": {
        "type": {"const": "para"},
        "parent_object": {
          "type": "string",
          "enum": [
            "magazine",
            "press_kit",
            "promo_only",
            "fanzine",
            "journal",
            "misc"
          ]
        },
        "parent_title": {"type": ["string", "null"]},
        "parent_issue": {"type": ["string", "null"]},
        "parent_year": {"type": ["integer", "null"]},
        "embedded_supports": {
          "type": "array",
          "items": {"$ref": "#/$defs/audio_support"},
          "default": []
        },
        "object_description": {"type": "string"}
      }
    }
  }
}
